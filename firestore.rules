rules_version = '2';

// AI MC 라이브 Q&A 보안 규칙 (운영자 인증 기반).
// - 참가자(비인증): 질문 생성만 가능(형식·길이 검증), control의 sessionId 읽기만 가능
// - 운영자(이메일/비밀번호 로그인): 질문 읽기·상태 변경, 무대 제어 쓰기
service cloud.firestore {
  match /databases/{database}/documents {

    match /questions/{questionId} {
      // 질문 목록(닉네임 포함)은 운영자·무대만 읽는다
      allow read: if request.auth != null;

      // 참가자 제출: 필드 형식과 길이를 검증해 스팸/거대 페이로드 차단
      allow create: if request.resource.data.text is string
        && request.resource.data.text.size() >= 4
        && request.resource.data.text.size() <= 200
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 1
        && request.resource.data.nickname.size() <= 20
        && request.resource.data.sessionId is string
        && request.resource.data.status == 'pending';

      // 승인/거절/답변 저장/방송완료 표시는 운영자 전용
      allow update: if request.auth != null;
      // 개인정보(닉네임·소속) 삭제도 운영자 전용 (세션 리셋·개별 삭제)
      allow delete: if request.auth != null;
    }

    match /control/{docId} {
      // 참가자 페이지가 현재 sessionId를 읽어야 하므로 읽기는 공개
      allow read: if true;
      // 세션 리셋·무대 재생 트리거는 운영자 전용
      allow write: if request.auth != null;
    }
  }
}
